<?xml version="1.0"?>
<launch> 
  <!-- Replace with your RealSense serial number here-->
  <arg name="rs_serial_no" default="151422250414"/>
  
  <!--Replace your node name if needed-->
  <!--Provide a ht_file that not exist, the camera should init with an identity matrix-->
  <node name="front_cam" pkg="py_ros_realsense" type="main.py" respawn="false" output="screen">
    <param name="rs_serial_no" type="string" value="$(arg rs_serial_no)"/>
    <param name="ht_file" type="string" value="$(find py_ros_realsense)/src/no_ht.pickle"/>
  </node>

</launch>